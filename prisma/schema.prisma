// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map(name: "created_at")
  updatedAt         DateTime @default(now()) @map(name: "updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map(name: "accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map(name: "sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?   // For email/password authentication
  image         String?
  createdAt     DateTime  @default(now()) @map(name: "created_at")
  updatedAt     DateTime  @default(now()) @map(name: "updated_at")
  hasPaid       Boolean?  @default(false)
  username      String?   @unique
  
  // Account status
  isVerified    Boolean   @default(false)
  isSuspended   Boolean   @default(false)
  lastLogin     DateTime?
  
  // Role-based fields
  role          String?   @default("CLIENT") // "CLIENT" | "FREELANCER"
  walletBalance Decimal   @default(0) @db.Decimal(12, 2)
  totalSpent    Decimal   @default(0) @db.Decimal(12, 2)
  totalEarned   Decimal   @default(0) @db.Decimal(12, 2)
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  freelancer    Freelancer?
  client        Client?
  projectsCreated Project[] @relation("ProjectCreator")
  projectsSubmitted Project[] @relation("ProjectSubmitter")
  requestsSent  Request[] @relation("RequestSender")
  requestsReceived Request[] @relation("RequestReceiver")
  transactions  Transaction[]
  activities    ActivityLog[]
  templatePurchases TemplatePurchase[]  // Templates purchased by this user
  
  // Stripe integration
  stripeCustomerId       String?   @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map(name: "stripe_subscription_id")
  stripePriceId          String?   @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")

  @@index([email])
  @@index([role])
  @@index([isSuspended])
  @@index([createdAt])
  @@map(name: "users")
}

model Freelancer {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title         String?
  bio           String?  @db.Text
  skills        String[] // Array of skill tags
  portfolio     String?  @db.Text
  hourlyRate    Decimal? @db.Decimal(10, 2)
  rating        Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount   Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map(name: "freelancers")
}

model Client {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  company       String?
  description   String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map(name: "clients")
}

model Template {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  category      String   // e.g., "website", "app", "design"
  image         String?
  price         Decimal  @db.Decimal(10, 2)
  
  features      String[] // Array of features
  uploaderId    String?  // Optional - may not be tracked in original schema
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations for purchases and tracking
  purchases     TemplatePurchase[]
  activities    ActivityLog[]

  @@map(name: "templates")
}

model TemplatePurchase {
  id            String   @id @default(cuid())
  
  templateId    String
  template      Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  purchasePrice Decimal  @db.Decimal(10, 2)
  downloadToken String   @unique  // Token for secure download
  
  status        String   @default("COMPLETED") // "PENDING", "COMPLETED", "REFUNDED"
  
  transactionId String?  // Reference to transaction if paid
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([userId, templateId])
  @@map(name: "template_purchases")
  @@index([templateId])
  @@index([userId])
  @@index([transactionId])
}

model Project {
  id            String   @id @default(cuid())
  title         String
  description   String   @db.Text
  budget        Decimal? @db.Decimal(12, 2)
  status        String   @default("OPEN") // "OPEN", "IN_PROGRESS", "COMPLETED", "CANCELLED"
  
  creatorId     String
  creator       User     @relation("ProjectCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  
  submiterId    String?
  submitter     User?    @relation("ProjectSubmitter", fields: [submiterId], references: [id])
  
  category      String?
  deadline      DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map(name: "projects")
}

model Request {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  status        String   @default("PENDING") // "PENDING", "ACCEPTED", "REJECTED", "COMPLETED"
  
  senderId      String
  sender        User     @relation("RequestSender", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId    String
  receiver      User     @relation("RequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  
  projectId     String?
  amount        Decimal? @db.Decimal(12, 2)
  dueDate       DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map(name: "requests")
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type          String   // "PAYMENT", "EARNING", "REFUND", "WITHDRAWAL"
  amount        Decimal  @db.Decimal(12, 2)
  netAmount     Decimal? @db.Decimal(12, 2) // Amount after commission (for freelancer earnings)
  commission    Decimal? @db.Decimal(12, 2) // Platform commission (5%)
  description   String?
  status        String   @default("PENDING") // "PENDING", "COMPLETED", "FAILED"
  
  stripeSessionId String? @unique
  stripeTransactionId String? @unique
  
  // Related user IDs for tracking sender/receiver pairs
  senderId      String?
  receiverId    String?
  
  projectId     String?
  requestId     String?
  templateId    String?
  
  // Resource tracking for related items
  relatedResourceType String?  // "TEMPLATE", "PROJECT", "REQUEST"
  relatedResourceId   String?  // The ID of the related resource
  
  metadata      Json?    // Additional data storage
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map(name: "transactions")
}

model Discount {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String   @default("PERCENTAGE") // "PERCENTAGE", "FIXED"
  discountValue Decimal  @db.Decimal(5, 2)
  maxUsage      Int?
  usageCount    Int      @default(0)
  expiresAt     DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map(name: "discounts")
}

model ActivityLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  action        String   // "TEMPLATE_VIEWED", "PURCHASE", "PROJECT_CREATED", "REQUEST_SENT"
  description   String?
  
  // Resource tracking
  resourceType  String?  // "TEMPLATE", "PROJECT", "REQUEST", "TRANSACTION"
  resourceId    String?  // The ID of the related resource
  
  metadata      Json?    // Flexible data storage
  
  // Optional template relation for convenience
  templateId    String?
  template      Template? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  
  @@map(name: "activity_logs")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map(name: "verification_tokens")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   Json?
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @default(now()) @map(name: "updated_at")
  authorId  String

  author User @relation(fields: [authorId], references: [id])

  @@map(name: "posts")
}
